{
  "$schema": "https://railway.com/railway.schema.json",
  "build": { "builder": "DOCKERFILE", "dockerfilePath": "backend/Dockerfile" },
  "deploy": { "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT", "healthcheckPath": "/api/v1/health", "restartPolicyType": "ON_FAILURE", "restartPolicyMaxRetries": 3 }
}
